SECRET_KEY=replace-with-a-secure-secret
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://your-domain.up.railway.app
DATABASE_URL=postgresql://user:password@host:5432/dbname
OPENAI_API_KEY=your-openai-key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_VISION_MODEL=gpt-4.1-mini
MAX_IMAGE_UPLOAD_MB=8
MAX_AUDIO_UPLOAD_MB=15
TIME_ZONE=Asia/Phnom_Penh
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=86400
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
OPERATOR_LOGIN_MAX_ATTEMPTS=5
OPERATOR_LOGIN_WINDOW_SECONDS=900
CHAT_RATE_LIMIT_MAX_REQUESTS=20
CHAT_RATE_LIMIT_WINDOW_SECONDS=60
TELEGRAM_RATE_LIMIT_MAX_REQUESTS=30
TELEGRAM_RATE_LIMIT_WINDOW_SECONDS=60
MAX_USER_MESSAGE_CHARS=4000
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_PATH=/webhooks/telegram/
